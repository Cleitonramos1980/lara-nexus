                  {
                      "id":  "in5",
                      "name":  "Build Outbound WhatsApp Text",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       -220,
                                       280
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "const sendActions = new Set([\n  \u0027enviar_boleto\u0027,\n  \u0027enviar_pix\u0027,\n  \u0027registrar_promessa\u0027,\n  \u0027negociar\u0027,\n  \u0027resposta_padrao\u0027,\n  \u0027escalar_humano\u0027,\n  \u0027optout_aplicado\u0027,\n  \u0027pausar_contato\u0027,\n]);\n\nconst output = [];\nfor (const item of $input.all()) {\n  const d = item.json || {};\n  if (d.status !== \u0027ok\u0027) continue;\n  if (!sendActions.has(String(d.acao || \u0027\u0027))) continue;\n  if (!d.mensagem) continue;\n\n  let text = String(d.mensagem);\n  if (d.acao === \u0027enviar_boleto\u0027 \u0026\u0026 d.payload_whatsapp) {\n    const linha = d.payload_whatsapp.linha_digitavel ? (\u0027\\nLinha digitavel: \u0027 + d.payload_whatsapp.linha_digitavel) : \u0027\u0027;\n    const url = d.payload_whatsapp.url_boleto ? (\u0027\\nURL boleto: \u0027 + d.payload_whatsapp.url_boleto) : \u0027\u0027;\n    text = text + linha + url;\n  }\n  if (d.acao === \u0027enviar_pix\u0027 \u0026\u0026 d.payload_whatsapp?.pix_copia_cola) {\n    text = text + \u0027\\n\\nPIX copia e cola:\\n\u0027 + d.payload_whatsapp.pix_copia_cola;\n  }\n\n  output.push({\n    json: {\n      to: String(d.wa_id || \u0027\u0027).trim(),\n      phone_number_id: String(d.phone_number_id || \u0027\u0027).trim(),\n      text,\n      lara_acao: d.acao,\n      lara_status: d.status,\n      codcli: d.codcli || \u0027\u0027,\n      cliente: d.cliente || \u0027\u0027,\n    },\n  });\n}\n\nreturn output;"
                                     }
