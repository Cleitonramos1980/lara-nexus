                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "const src = $input.first()?.json || {};\nconst query = (src.query \u0026\u0026 typeof src.query === \u0027object\u0027) ? src.query : src;\n\nconst mode = String(query[\u0027hub.mode\u0027] ?? query.hub_mode ?? query.mode ?? \u0027\u0027).trim();\nconst verifyToken = String(query[\u0027hub.verify_token\u0027] ?? query.hub_verify_token ?? query.verify_token ?? \u0027\u0027).trim();\nconst challenge = String(query[\u0027hub.challenge\u0027] ?? query.hub_challenge ?? query.challenge ?? \u0027\u0027).trim();\n\nconst expectedToken = String($env.WHATSAPP_VERIFY_TOKEN || \u0027\u0027).trim();\n\nconst valid = Boolean(\n  mode === \u0027subscribe\u0027 \u0026\u0026\n  challenge \u0026\u0026\n  expectedToken \u0026\u0026\n  verifyToken === expectedToken\n);\n\nreturn [{\n  json: {\n    valid,\n    challenge,\n    mode,\n    error: valid ? \u0027\u0027 : \u0027invalid verify token, mode, or challenge\u0027,\n  },\n}];"
                                     }
