                  {
                      "id":  "in2",
                      "name":  "Normalize Inbound Message",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       -930,
                                       280
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "function messageTextFromMessage(msg) {\n  if (!msg || typeof msg !== \u0027object\u0027) return \u0027\u0027;\n  const type = msg.type || \u0027\u0027;\n\n  if (type === \u0027text\u0027) return String(msg.text?.body || \u0027\u0027).trim();\n  if (type === \u0027button\u0027) return String(msg.button?.text || \u0027\u0027).trim();\n  if (type === \u0027interactive\u0027) {\n    const replyId = msg.interactive?.button_reply?.id || msg.interactive?.list_reply?.id || \u0027\u0027;\n    const replyTitle = msg.interactive?.button_reply?.title || msg.interactive?.list_reply?.title || \u0027\u0027;\n    return String(replyTitle || replyId || \u0027\u0027).trim();\n  }\n  if (type === \u0027image\u0027) return \u0027[imagem]\u0027;\n  if (type === \u0027document\u0027) return \u0027[documento]\u0027;\n  if (type === \u0027audio\u0027) return \u0027[audio]\u0027;\n  if (type === \u0027video\u0027) return \u0027[video]\u0027;\n\n  return String(msg.caption || \u0027\u0027).trim();\n}\n\nconst input = $input.first()?.json || {};\nconst out = [];\nconst entries = Array.isArray(input.entry) ? input.entry : [];\n\nfor (const entry of entries) {\n  const changes = Array.isArray(entry?.changes) ? entry.changes : [];\n  for (const change of changes) {\n    const value = change?.value || {};\n    const messages = Array.isArray(value.messages) ? value.messages : [];\n\n    for (const msg of messages) {\n      const waId = String(msg?.from || \u0027\u0027).trim();\n      const messageText = messageTextFromMessage(msg);\n      if (!waId || !messageText) continue;\n\n      const tsRaw = String(msg?.timestamp || \u0027\u0027).trim();\n      const tsNumber = Number(tsRaw);\n      const receivedAt = Number.isFinite(tsNumber) \u0026\u0026 tsNumber \u003e 0\n        ? new Date(tsNumber * 1000).toISOString()\n        : new Date().toISOString();\n\n      out.push({\n        json: {\n          event_id: String(msg?.id || (waId + \u0027-\u0027 + Date.now())).trim(),\n          wa_id: waId,\n          telefone: waId,\n          message_text: messageText,\n          tenant_id: String(input.tenant_id || \u0027default\u0027).trim() || \u0027default\u0027,\n          jurisdicao: \u0027BR\u0027,\n          canal: \u0027WHATSAPP\u0027,\n          received_at: receivedAt,\n          phone_number_id: String(value?.metadata?.phone_number_id || \u0027\u0027).trim(),\n          payload: {\n            entry_id: entry?.id,\n            change_field: change?.field,\n            message_type: msg?.type,\n            raw_message: msg,\n          },\n        },\n      });\n    }\n  }\n}\n\nreturn out;"
                                     }
                  },
