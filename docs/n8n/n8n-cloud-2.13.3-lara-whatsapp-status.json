                      "name":  "Normalize Status Event",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       -460,
                                       260
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "const input = $input.first()?.json || {};\nconst out = [];\nconst entries = Array.isArray(input.entry) ? input.entry : [];\n\nfor (const entry of entries) {\n  const changes = Array.isArray(entry?.changes) ? entry.changes : [];\n  for (const change of changes) {\n    const value = change?.value || {};\n    const statuses = Array.isArray(value.statuses) ? value.statuses : [];\n\n    for (const st of statuses) {\n      const messageId = String(st?.id || \u0027\u0027).trim();\n      const waId = String(st?.recipient_id || \u0027\u0027).trim();\n      const status = String(st?.status || \u0027\u0027).trim();\n      const timestamp = st?.timestamp ? new Date(Number(st.timestamp) * 1000).toISOString() : new Date().toISOString();\n      if (!messageId || !status) continue;\n\n      out.push({\n        json: {\n          event_id: messageId + \u0027:\u0027 + status + \u0027:\u0027 + timestamp,\n          message_id: messageId,\n          wa_id: waId,\n          status,\n          timestamp,\n          payload: {\n            entry_id: entry?.id,\n            change_field: change?.field,\n            raw_status: st,\n          },\n        },\n      });\n    }\n  }\n}\n\nreturn out;"
                                     }
                  },
